<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.Sweepic" parent="">
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/sw_bk</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <style name="TextAppearance.Sweepic.Bold">
        <item name="fontFamily">@font/pretendard_bold</item>
        <item name="android:textColor">@color/sw_bk</item>
    </style>
    
    <style name="TextAppearance.Sweepic.Bold.Title_20sp">
        <item name="android:textSize">20sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Bold.Title_18sp">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Bold.Title_16sp">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Bold.Title_14sp">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Bold.Caption_13_B">
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Medium">
        <item name="fontFamily">@font/pretendard_medium</item>
        <item name="android:textColor">@color/sw_bk</item>
    </style>

    <style name="TextAppearance.Sweepic.Medium.Body_14_M">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Medium.Body_13_M">
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Regular">
        <item name="fontFamily">@font/pretendard_regular</item>
        <item name="android:textColor">@color/sw_bk</item>
    </style>

    <style name="TextAppearance.Sweepic.Regular.Body_16_R">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Regular.Body_14_R">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.Sweepic.Regular.Caption_13_R">
        <item name="android:textSize">13sp</item>
    </style>

    <style name="TextAppearance.Sweepic.InActiveBnv">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.Sweepic.ActiveBnv">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/sweepic</item>
    </style>

    <style name="TextAppearance.Sweepic.TopBar">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/sw_bk</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Sweepic.Content">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Sweepic.Content.Light">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.Sweepic.Warning">
        <item name="android:textColor">@color/warning</item>
    </style>

    <style name="MyDialogStyle" parent="Theme.Material3.Light.Dialog">
        <!-- 다이얼로그 배경 색상 설정 -->
        <item name="android:windowBackground">@android:color/transparent</item>
        <!-- 배경 디밍 활성화 -->
        <item name="android:backgroundDimEnabled">true</item>
        <!-- 배경 디밍 정도 설정 (0.0 ~ 1.0) -->
        <item name="android:backgroundDimAmount">0.8</item>
    </style>
</resources>