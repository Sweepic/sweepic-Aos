<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_rect_10_white_fill">

        <TextView
            android:id="@+id/tv_dialog_goal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="목표 장수 설정"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="26dp"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진 정리 목표를 설정하세요"
            android:textSize="13sp"
            android:textColor="@color/sw_gray2"
            app:layout_constraintTop_toBottomOf="@id/tv_dialog_goal_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="10dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tv_dialog_goal_title"
            app:layout_constraintBottom_toTopOf="@id/btn_goal_dialog_cancel"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목표 장수 설정"
                android:textColor="@color/sw_gray2"
                android:textSize="13sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="@id/et_input_goal"
                android:layout_marginTop="20dp"/>

            <EditText
                android:id="@+id/et_input_goal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:hint="원하는 목표 장수를 입력해주세요"
                android:textColorHint="@color/sw_gray2"
                android:textColor="@color/black"
                android:maxLength="10"
                android:layout_marginHorizontal="26dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="38dp"/>

            <TextView
                android:id="@+id/tv_goal_warning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="현재 사진 수보다 많은 목표는 설정할 수 없습니다."
                android:textSize="13sp"
                android:textColor="@color/warning"
                android:visibility="invisible"
                app:layout_constraintStart_toStartOf="@id/et_input_goal"
                app:layout_constraintTop_toBottomOf="@id/et_input_goal"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_goal_dialog_cancel"
            android:layout_width="140dp"
            android:layout_height="36dp"
            android:text="취소"
            android:textStyle="bold"
            android:background="@drawable/shape_rect_4_white_fill"
            android:textColor="@color/sw_gray2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_input"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_goal_dialog_confirm"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_goal_dialog_confirm"
            android:layout_width="140dp"
            android:layout_height="36dp"
            android:text="완성"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/shape_rect_4_blue_fill"
            app:layout_constraintStart_toEndOf="@id/btn_goal_dialog_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_input"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>