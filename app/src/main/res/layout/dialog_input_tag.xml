<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_rect_26_white_fill_gray_line">

        <TextView
            android:id="@+id/tv_sweep_input_location_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#장소 입력하기"
            style="@style/TextAppearance.Sweepic.Content"
            android:textSize="17sp"
            android:textColor="@color/sw_bk"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="26dp"/>

        <EditText
            android:id="@+id/et_sweep_input_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content.Light"
            android:hint="장소를 입력해주세요."
            android:textColorHint="@color/sw_gray2"
            android:textColor="@color/sw_bk"
            android:layout_marginHorizontal="26dp"
            app:layout_constraintTop_toBottomOf="@id/tv_sweep_input_location_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            android:layout_marginTop="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_input_location_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="취소"
            style="@style/TextAppearance.Sweepic.Content"
            android:background="@null"
            android:textColor="@color/sw_gray2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_sweep_input_location"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_input_location_confirm"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="27dp"
            android:layout_marginHorizontal="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_input_location_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="완성"
            style="@style/TextAppearance.Sweepic.Content"
            android:background="@drawable/shape_rect_4_blue_fill"
            app:layout_constraintStart_toEndOf="@id/btn_input_location_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_sweep_input_location"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="27dp"
            android:layout_marginHorizontal="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>