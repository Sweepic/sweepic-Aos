<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <TextView
            android:id="@+id/tv_sweep_topbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진정리"
            style="@style/TextAppearance.Sweepic.Bold.Title_18sp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iv_challenge_back_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_back"
            android:layout_marginStart="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_sweep_topbar"
            app:layout_constraintBottom_toBottomOf="@+id/tv_sweep_topbar"/>

        <View
            android:id="@+id/view_sweep_topbar_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sw_gray1"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_sweep_topbar" />

        <ImageView
            android:id="@+id/iv_sweep_move"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_move"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/view_sweep_topbar_line"/>

        <ImageView
            android:id="@+id/iv_sweep_memo"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_memo"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@+id/iv_sweep_move"
            app:layout_constraintTop_toTopOf="@+id/iv_sweep_move"/>

        <ImageView
            android:id="@+id/iv_sweep_trash"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_trash_can"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@id/iv_sweep_memo"
            app:layout_constraintTop_toTopOf="@+id/iv_sweep_move"/>

        <TextView
            android:id="@+id/tv_sweep_trash_count"
            android:layout_width="27dp"
            android:layout_height="17dp"
            android:text="99+"
            android:gravity="center"
            style="@style/TextAppearance.Sweepic.Content"
            android:background="@drawable/shape_rect_8_blue_fill"
            android:layout_marginStart="12dp"
            android:layout_marginTop="-2dp"
            app:layout_constraintTop_toTopOf="@id/iv_sweep_trash"
            app:layout_constraintStart_toStartOf="@id/iv_sweep_trash"/>

        <TextView
            android:id="@+id/tv_sweep_quit"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:text="챌린지 완료"
            android:gravity="center"
            style="@style/TextAppearance.Sweepic.Bold.Title_14sp"
            android:textColor="@color/white"
            android:background="@drawable/shape_rect_4_blue_fill"
            android:clickable="true"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="@id/iv_sweep_move"
            app:layout_constraintBottom_toBottomOf="@id/iv_sweep_move"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_sweep_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content.Light"
            android:text="00. 00. 00 오후 00:00"
            android:textColor="@color/sw_gray2"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@+id/iv_sweep_move"
            app:layout_constraintStart_toStartOf="@+id/iv_sweep_move"/>

        <TextView
            android:id="@+id/tv_sweep_total_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content"
            android:textColor="@color/sw_gray2"
            android:text="n"
            app:layout_constraintEnd_toEndOf="@+id/tv_sweep_quit"
            app:layout_constraintTop_toTopOf="@+id/tv_sweep_date"/>

        <TextView
            android:id="@+id/tv_sweep_divide_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content"
            android:textColor="@color/sw_gray2"
            android:text="/"
            android:layout_marginEnd="2dp"
            app:layout_constraintEnd_toStartOf="@+id/tv_sweep_total_count"
            app:layout_constraintTop_toTopOf="@+id/tv_sweep_date"/>

        <TextView
            android:id="@+id/tv_sweep_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content"
            android:textColor="@color/sw_point"
            android:text="1"
            android:layout_marginEnd="2dp"
            app:layout_constraintTop_toTopOf="@+id/tv_sweep_date"
            app:layout_constraintEnd_toStartOf="@+id/tv_sweep_divide_count"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_sweep_main_img"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="18dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_sweep_date"
            app:layout_constraintBottom_toTopOf="@id/sv_sweep_ai_tag" />

        <!-- 왼쪽 터치 영역 -->
        <View
            android:id="@+id/view_left_touch"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:layout_gravity="start"
            android:layout_marginEnd="200dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/vp_sweep_main_img"
            app:layout_constraintBottom_toBottomOf="@id/vp_sweep_main_img"
            app:layout_constraintEnd_toStartOf="@id/view_right_touch" />

        <!-- 오른쪽 터치 영역 -->
        <View
            android:id="@+id/view_right_touch"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:layout_gravity="end"
            app:layout_constraintStart_toEndOf="@id/view_left_touch"
            app:layout_constraintTop_toTopOf="@id/vp_sweep_main_img"
            app:layout_constraintBottom_toBottomOf="@id/vp_sweep_main_img"
            app:layout_constraintEnd_toEndOf="parent" />

        <HorizontalScrollView
            android:id="@+id/sv_sweep_ai_tag"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/sw_gray_lightly"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none"
            app:layout_constraintBottom_toTopOf="@id/view_sweep_bottom_bar_line">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical">

<!--                <com.google.android.material.materialswitch.MaterialSwitch-->
<!--                    android:id="@+id/switch_sweep_ai_btn"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="match_parent"-->
<!--                    android:background="@color/transparent"-->
<!--                    app:trackTint="@drawable/sel_sweep_ai_toggle_track"-->
<!--                    app:thumbTint="@drawable/sel_sweep_ai_toggle_thumb"-->
<!--                    android:layout_marginStart="18dp"-->
<!--                    app:layout_constraintTop_toTopOf="parent"-->
<!--                    app:layout_constraintStart_toStartOf="parent"/>-->

<!--                <TextView-->
<!--                    android:id="@+id/tv_sweep_ai_on"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="AI"-->
<!--                    style="@style/TextAppearance.Sweepic.Content.Light"-->
<!--                    android:visibility="gone"-->
<!--                    android:layout_marginStart="8sp"-->
<!--                    app:layout_constraintStart_toStartOf="@id/switch_sweep_ai_btn"-->
<!--                    app:layout_constraintTop_toTopOf="@id/switch_sweep_ai_btn"-->
<!--                    app:layout_constraintBottom_toBottomOf="@id/switch_sweep_ai_btn" />-->

                <TextView
                    android:id="@+id/tv_sweep_location_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/TextAppearance.Sweepic.Medium.Body_14_M"
                    android:textSize="15sp"
                    android:background="@drawable/shape_rect_16_gray_line"
                    android:tag="#장소"
                    android:text="#장소"
                    android:textColor="@color/sw_gray2"
                    android:paddingStart="19dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="15dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/tv_sweep_people_tag"/>

                <TextView
                    android:id="@+id/tv_sweep_people_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/TextAppearance.Sweepic.Medium.Body_14_M"
                    android:textSize="15sp"
                    android:background="@drawable/shape_rect_16_gray_line"
                    android:tag="#사람"
                    android:text="#사람"
                    android:textColor="@color/sw_gray2"
                    android:paddingStart="19dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/tv_sweep_location_tag"
                    app:layout_constraintEnd_toStartOf="@+id/tv_sweep_food_tag"/>

                <TextView
                    android:id="@+id/tv_sweep_food_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/TextAppearance.Sweepic.Medium.Body_14_M"
                    android:textSize="15sp"
                    android:background="@drawable/shape_rect_16_gray_line"
                    android:tag="#음식"
                    android:text="#음식"
                    android:textColor="@color/sw_gray2"
                    android:paddingStart="19dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/tv_sweep_people_tag"
                    app:layout_constraintEnd_toStartOf="@+id/tv_sweep_etc_tag"/>

                <TextView
                    android:id="@+id/tv_sweep_etc_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/TextAppearance.Sweepic.Medium.Body_14_M"
                    android:textSize="15sp"
                    android:background="@drawable/shape_rect_16_gray_line"
                    android:tag="#기타"
                    android:text="#기타"
                    android:textColor="@color/sw_gray2"
                    android:paddingStart="19dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/tv_sweep_food_tag"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <View
                    android:layout_width="10dp"
                    android:layout_height="match_parent"
                    app:layout_constraintStart_toEndOf="@+id/tv_sweep_etc_tag"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </HorizontalScrollView>

        <View
            android:id="@+id/view_sweep_bottom_bar_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sw_gray1"
            android:layout_marginTop="18dp"
            app:layout_constraintBottom_toTopOf="@+id/layout_sweep_bottom_bar"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_sweep_bottom_bar"
            android:layout_width="0dp"
            android:layout_height="85dp"
            android:background="@color/white"
            app:layout_constraintTop_toBottomOf="@+id/sv_sweep_ai_tag"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- iv_sweep_add_folder: 앨범 추가 버튼 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_sweep_add_folder_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/iv_sweep_add_folder"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_add_folder"
                    android:layout_marginTop="15dp"
                    android:layout_marginStart="30dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/tv_sweep_add_folder"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.Sweepic.Content.Light"
                    android:text="앨범추가"
                    android:textColor="@color/sw_bk"
                    android:gravity="center"
                    app:layout_constraintTop_toBottomOf="@+id/iv_sweep_add_folder"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- RecyclerView: 앨범 목록 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_sweep_save_to_album"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                tools:listitem="@layout/item_sweep_folder"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constrainedWidth="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/layout_sweep_add_folder_container"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <data>

    </data>
</layout>