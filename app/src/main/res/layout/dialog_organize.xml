<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="328dp"
    android:layout_height="144dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/tv_dialog_today"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘 새로운 사진 82장 추가됐어요!"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tv_dialog_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="지금 정리할까요?"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_today"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    

    <android.widget.Button
        android:id="@+id/btn_later"
        android:layout_width="140dp"
        android:layout_height="36dp"
        android:background="@drawable/btn_challenge"
        android:backgroundTint="@color/white"
        android:text="나중에 하기"
        android:textColor="@color/gray"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_msg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="20dp"/>

    <android.widget.Button
        android:id="@+id/btn_organize"
        android:layout_width="140dp"
        android:layout_height="36dp"
        android:background="@drawable/btn_challenge"
        android:text="정리하기"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/btn_later"
        app:layout_constraintStart_toEndOf="@id/btn_later"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>