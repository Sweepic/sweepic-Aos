<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_rect_26_white_fill_gray_line">

        <TextView
            android:id="@+id/tv_add_folder_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="새 앨범 추가하기"
            style="@style/TextAppearance.Sweepic.Bold.Title_16sp"
            android:textSize="17sp"
            android:textColor="@color/sw_bk"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="26dp"/>

        <TextView
            android:id="@+id/tv_add_folder_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Regular.Caption_13_R"
            android:textSize="15sp"
            android:text="새 앨범은 안드로이드 사진첩에 만들어 집니다."
            android:textColor="@color/sw_gray2"
            android:gravity="center"
            android:layout_marginHorizontal="26dp"
            app:layout_constraintTop_toBottomOf="@id/tv_add_folder_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/et_add_album_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Regular.Body_16_R"
            android:hint="추가할 앨범 명을 입력해주세요."
            android:textColorHint="@color/sw_gray2"
            android:textColor="@color/sw_bk"
            android:layout_marginHorizontal="26dp"
            app:layout_constraintTop_toBottomOf="@id/tv_add_folder_warning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            android:layout_marginTop="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_folder_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="취소"
            style="@style/TextAppearance.Sweepic.Bold.Title_14sp"
            android:background="@drawable/shape_rect_4_gray_line"
            android:textColor="@color/sw_gray2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_add_album_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_add_folder_confirm"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="27dp"
            android:layout_marginHorizontal="15dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_folder_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="추가"
            style="@style/TextAppearance.Sweepic.Bold.Title_14sp"
            android:textColor="@color/white"
            android:background="@drawable/shape_rect_4_blue_fill"
            app:layout_constraintStart_toEndOf="@id/btn_add_folder_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/et_add_album_name"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="27dp"
            android:layout_marginHorizontal="15dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>