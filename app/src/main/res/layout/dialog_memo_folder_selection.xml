<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="20dp">

    <!-- 제목 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="폴더 선택하기"
        android:textColor="@color/sw_gray3"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- 설명 -->
    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="이동할 폴더를 선택해주세요."
        android:textStyle="bold"
        android:textColor="@color/sw_gray2"
        android:textSize="13sp"
        android:gravity="center"
        android:paddingBottom="20dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <RadioGroup
        android:id="@+id/folderOptionsGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stateListAnimator="@null"
        android:background="@null"
        android:orientation="vertical"
        android:paddingVertical="4dp"/>
    </androidx.core.widget.NestedScrollView>


<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="100dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_memo_cancel"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textColor="@color/sw_gray2"
            android:text="취소" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/moveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_memo_confirm"
            android:layout_weight="1"
            android:text="이동"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>


