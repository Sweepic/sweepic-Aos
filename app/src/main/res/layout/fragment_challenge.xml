<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_top"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="24dp">

            <ImageView
                android:src="@drawable/logo_sweepic"
                android:layout_width="127dp"
                android:layout_height="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="16dp"
                android:layout_marginStart="20dp"/>

            <ImageView
                android:id="@+id/iv_mypage"
                android:src="@drawable/ic_mypage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="16dp"/>

            <View
                android:id="@+id/view"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:background="@color/gray_line"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/target"
            android:layout_width="328dp"
            android:layout_height="128dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_top"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="김지형님"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="24dp"/>

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="의 목표"
                android:textSize="16sp"
                app:layout_constraintStart_toEndOf="@id/tv_name"
                app:layout_constraintTop_toTopOf="@id/tv_name" />

            <TextView
                android:id="@+id/tv_target_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="10,000"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_name"
                app:layout_goneMarginTop="5dp"/>

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장까지"
                android:textSize="16sp"
                android:textStyle="normal"
                app:layout_constraintBottom_toBottomOf="@+id/tv_target_number"
                app:layout_constraintStart_toEndOf="@id/tv_target_number"/>

            <TextView
                android:id="@+id/tv_recent_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:text="1,579"
                android:textColor="@color/sweepic_point"
                app:layout_constraintTop_toBottomOf="@id/tv_target_number"
                app:layout_constraintStart_toStartOf="@id/tv_target_number"
                android:layout_marginTop="5dp"/>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/sweepic_point"
                app:layout_constraintStart_toEndOf="@id/tv_recent_number"
                app:layout_constraintBottom_toBottomOf="@id/tv_recent_number" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="남았어요!"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@+id/textView2"
                app:layout_constraintStart_toEndOf="@+id/textView2"
                android:layout_marginStart="5dp"/>

            <TextView
                android:id="@+id/tv_total_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textSize="13sp"
                android:textColor="@color/gray"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="56dp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="11,579"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sweepic"
                app:layout_constraintStart_toStartOf="@+id/tv_total_text"
                app:layout_constraintTop_toBottomOf="@+id/tv_total_text"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sweepic"
                app:layout_constraintBottom_toBottomOf="@+id/tv_total"
                app:layout_constraintStart_toEndOf="@+id/tv_total" />

            <View
                android:id="@+id/view2"
                android:layout_width="93dp"
                android:layout_height="1dp"
                android:layout_marginTop="4dp"
                android:background="@color/gray_line"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <TextView
                android:id="@+id/tv_today_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="13sp"
                android:textColor="@color/gray"
                app:layout_constraintStart_toStartOf="@+id/tv_total"
                app:layout_constraintTop_toBottomOf="@id/view2"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tv_today"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="17"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sweepic"
                app:layout_constraintStart_toStartOf="@+id/tv_today_text"
                app:layout_constraintTop_toBottomOf="@+id/tv_today_text"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="장"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/sweepic"
                app:layout_constraintStart_toEndOf="@id/tv_today"
                app:layout_constraintBottom_toBottomOf="@id/tv_today" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@+id/target"
            app:tabIndicatorColor="@color/black"
            app:tabTextColor="@color/gray"
            app:tabSelectedTextColor="@color/black"
            android:textSize="14sp"
            android:background="@color/white"
            app:tabIndicatorFullWidth="true"
            app:tabRippleColor="@color/Transparency"/>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_challenge"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_layout"
            tools:layout_editor_absoluteX="0dp"
            android:nestedScrollingEnabled="true"
            android:clipToPadding="false">
        </androidx.viewpager2.widget.ViewPager2>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>