<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_numphoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="몇 장"
        style="@style/TextAppearance.Sweepic.Bold.Caption_13_B"
        android:textSize="14sp"
        android:textColor="@color/sweepic_point"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_challenge_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="챌린지 제목"
        style="@style/TextAppearance.Sweepic.Medium.Body_13_M"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="@id/tv_numphoto"
        app:layout_constraintStart_toEndOf="@id/tv_numphoto"
        app:layout_constraintBottom_toBottomOf="@+id/tv_numphoto"
        android:layout_marginStart="4dp"/>

    <ImageView
        android:id="@+id/iv_challenge_img"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_numphoto" />

    <ImageView
        android:id="@+id/iv_challenge_img2"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintDimensionRatio="1:1"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="@+id/iv_challenge_img"
        app:layout_constraintBottom_toBottomOf="@+id/iv_challenge_img"
        app:layout_constraintStart_toEndOf="@+id/iv_challenge_img"
        app:layout_constraintEnd_toStartOf="@+id/iv_challenge_img3"/>

    <ImageView
        android:id="@+id/iv_challenge_img3"
        android:layout_width="110dp"
        android:layout_height="110dp"
        app:layout_constraintDimensionRatio="1:1"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="@+id/iv_challenge_img2"
        app:layout_constraintBottom_toBottomOf="@+id/iv_challenge_img2"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/btn_challenge_start"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/btn_challenge"
        android:text="도전하기"
        style="@style/TextAppearance.Sweepic.Bold.Title_14sp"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/iv_challenge_img"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="18dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>