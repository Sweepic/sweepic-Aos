<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- WebView를 화면 전체로 설정 -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:elevation="10dp"/>
    </FrameLayout>
    <!-- 앱 로고 -->
    <ImageView
        app:layout_constraintTop_toTopOf="parent"
        android:id="@+id/iv_login_logo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_sweepic"
        android:layout_marginTop="200dp"/>

    <!--카카오 로그인버튼-->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/kakaoLoginLayout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/shape_rect_4_gray_line"
        app:layout_constraintTop_toBottomOf="@+id/iv_login_logo"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="280dp"
        android:layout_marginBottom="10dp">

    <ImageView
        android:id="@+id/iv_login_kakao"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_kakao"
        app:layout_constraintEnd_toStartOf="@id/tv_login_kakao"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/kakaoLoginLayout"
        app:layout_constraintBottom_toBottomOf="@id/kakaoLoginLayout"/>

    <TextView
        android:id="@+id/tv_login_kakao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="카카오로 시작하기"
        android:textColor="@color/sw_bk"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@id/kakaoLoginLayout"
        app:layout_constraintTop_toTopOf="@id/kakaoLoginLayout"
        app:layout_constraintBottom_toBottomOf="@id/kakaoLoginLayout"
        app:layout_constraintEnd_toEndOf="@id/kakaoLoginLayout"
        android:textStyle="bold" />

</androidx.constraintlayout.widget.ConstraintLayout>




</androidx.constraintlayout.widget.ConstraintLayout>
