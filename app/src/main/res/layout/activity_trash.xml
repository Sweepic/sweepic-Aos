<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <TextView
            android:id="@+id/tv_trash_topbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="휴지통"
            style="@style/TextAppearance.Sweepic.TopBar"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iv_trash_back_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_btn"
            android:layout_marginStart="30dp"
            app:layout_constraintTop_toTopOf="@id/tv_trash_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/view_trash_topbar_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sw_gray1"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_trash_topbar" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_trash_gallery"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="17dp"
            android:layout_marginHorizontal="18dp"
            android:scrollbars="vertical"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/view_trash_topbar_line"
            app:layout_constraintBottom_toTopOf="@+id/tv_trash_delete"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tv_trash_delete"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/sweepic"
            style="@style/TextAppearance.Sweepic.Content"
            android:text="모든 사진 삭제하기"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/tv_trash_restore"/>

        <TextView
            android:id="@+id/tv_trash_restore"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@color/white"
            style="@style/TextAppearance.Sweepic.Content"
            android:text="모든 사진 복구하기"
            android:textColor="@color/black"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>