<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/shape_rect_26_white_fill_gray_line">
        
        <ImageView
            android:id="@+id/iv_check"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_dialog_check"
            android:layout_marginTop="25dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tv_trash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사진이 지워졌습니다!"
            style="@style/TextAppearance.Sweepic.Content"
            android:textSize="17sp"
            android:textColor="@color/sw_bk"
            app:layout_constraintTop_toBottomOf="@+id/iv_check"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="15dp"/>

        <TextView
            android:id="@+id/tv_trash_warning"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            style="@style/TextAppearance.Sweepic.Content.Light"
            android:text="지워진 사진들은 30일 이내에 기본 갤러리에서\n다시 복구할 수 있습니다."
            android:textColor="@color/sw_gray2"
            android:gravity="center"
            android:layout_marginHorizontal="26dp"
            app:layout_constraintTop_toBottomOf="@id/tv_trash_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0"
            android:layout_marginTop="15dp"/>

        <View
            android:id="@+id/view_div_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sw_gray1"
            android:layout_marginTop="18dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_trash_delete_confirm"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_trash_delete_confirm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="확인"
            style="@style/TextAppearance.Sweepic.Content"
            android:background="@null"
            android:textColor="@color/sw_bk"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_trash_warning"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:layout_marginHorizontal="20dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>