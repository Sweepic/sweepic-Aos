<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true"
        android:overScrollMode="never">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

            <!--인기 태그 모아보기-->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_marginTop="16dp"
                android:layout_marginBottom="30dp"
                android:id="@+id/layout_record_mainhistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                >
                <!--월 타이틀-->
                <LinearLayout
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:orientation="horizontal"
                    android:id="@+id/layout_monthtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp">

                    <TextView
                        android:id="@+id/tv_record_monthtitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"

                        android:text="12월"
                        android:textColor="@color/sw_bk"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/ic_next"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_next" />

                </LinearLayout>

                <!--카드형태 태그리스트-->

                <!-- 가장 많이 간 장소 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_record_place"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="2dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="10dp"
                    app:layout_constraintEnd_toStartOf="@id/cv_record_people"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_monthtitle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tv_record_place"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="가장 많이 간 장소"
                            android:textColor="@color/sw_bk"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tv_record_visittag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#인하대학교"
                            android:textColor="@color/sw_bk"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 가장 많이 만난 사람 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_record_people"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="2dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintStart_toEndOf="@id/cv_record_place"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_monthtitle">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tv_record_people"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="가장 많이 만난 사람"
                            android:textColor="@color/sw_bk"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tv_record_peopletag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#유진언니"
                            android:textColor="@color/sw_bk"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- 가장 많이 먹은 음식 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_record_food"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="2dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/cv_record_people"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cv_record_place"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tv_record_food"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="가장 많이 먹은 음식"
                            android:textColor="@color/sw_bk"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tv_record_foodtag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#아메리카노"
                            android:textColor="@color/sw_bk"
                            android:textStyle="bold"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </androidx.constraintlayout.widget.ConstraintLayout>


                <!--어워드-->
                <!--어워드 타이틀-->
        <!--월 타이틀-->
        <LinearLayout
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:orientation="horizontal"
            android:id="@+id/layout_awardtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tv_record_awardtitle"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="어워드"
                android:textColor="@color/sw_bk"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
        <!-- 12월 베스트 사진 Top5 -->
        <LinearLayout
            android:id="@+id/layout_subtitle1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_record_subtitle1"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="12월 베스트 사진 Top5"
                android:textColor="@color/sw_bk"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_next" />
        </LinearLayout>

        <!-- 사진 리스트 (12월 베스트 사진 Top5) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_best_pictures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:overScrollMode="never"
            android:orientation="horizontal"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        <!-- 지난 베스트 사진 타이틀 -->
        <LinearLayout
            android:id="@+id/layout_subtitle2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_record_subtitle2"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="지난 베스트 사진"
                android:textColor="@color/sw_bk"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_next" />
        </LinearLayout>

        <!-- 사진 리스트 (지난 베스트 사진) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_best_pictures_past"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:overScrollMode="never"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            app:spanCount="3" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
</layout>
