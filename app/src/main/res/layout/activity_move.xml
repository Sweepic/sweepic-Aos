<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <TextView
            android:id="@+id/tv_move_topbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이동하기"
            style="@style/TextAppearance.Sweepic.Bold.Title_18sp"
            android:textSize="20sp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/iv_move_back_btn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back_btn"
            android:layout_marginStart="30dp"
            app:layout_constraintTop_toTopOf="@id/tv_move_topbar"
            app:layout_constraintBottom_toBottomOf="@+id/tv_move_topbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/view_move_topbar_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/sw_gray1"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_move_topbar" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_move_gallery"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="17dp"
            android:layout_marginHorizontal="18dp"
            android:scrollbars="vertical"
            app:layout_constraintTop_toBottomOf="@id/view_move_topbar_line"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_move_scroll_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/fab_move_scroll_down"
            app:borderWidth="0dp"
            android:backgroundTint="@color/sw_gray1"
            android:foreground="@drawable/ic_fab_up"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_move_scroll_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginBottom="40dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:backgroundTint="@color/sw_gray1"
            android:foreground="@drawable/ic_fab_down"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>